generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  runtime       = "nodejs"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ── NextAuth ──────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App Models ────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for OAuth-only users
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  tables         Table[]
  collaborations Collaborator[]
  tableVersions  TableVersion[] @relation("VersionAuthor")
}

model Table {
  id           String   @id @default(cuid())
  name         String
  description  String?
  published    Boolean  @default(false)
  ownerId      String
  forkedFromId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  forkedFrom    Table?         @relation("TableForks", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks         Table[]        @relation("TableForks")
  versions      TableVersion[]
  collaborators Collaborator[]

  @@map("tables")
}

model TableVersion {
  id        String   @id @default(cuid())
  tableId   String
  version   Int
  schema    Json
  data      Json?
  message   String?
  createdAt DateTime @default(now())
  authorId  String

  table  Table @relation(fields: [tableId], references: [id], onDelete: Cascade)
  author User  @relation("VersionAuthor", fields: [authorId], references: [id])

  @@unique([tableId, version])
  @@map("table_versions")
}

enum CollaboratorRole {
  VIEWER
  EDITOR
  ADMIN
}

model Collaborator {
  id        String           @id @default(cuid())
  tableId   String
  userId    String
  role      CollaboratorRole @default(VIEWER)
  createdAt DateTime         @default(now())

  table Table @relation(fields: [tableId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tableId, userId])
  @@map("collaborators")
}
