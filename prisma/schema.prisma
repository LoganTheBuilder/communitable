generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ── BetterAuth-managed tables ────────────────────────────────────────────────
// These models exist so Prisma can generate migrations for them.
// DO NOT query these directly — use BetterAuth APIs instead.

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  accounts Account[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ── App Models ───────────────────────────────────────────────────────────────

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique // BetterAuth user ID
  displayName String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tables         Table[]
  collaborations Collaborator[]
  tableVersions  TableVersion[] @relation("VersionAuthor")

  @@map("profiles")
}

model Table {
  id                String    @id @default(cuid())
  name              String
  description       String?
  published         Boolean   @default(false)
  viewCount         Int       @default(0)
  ownerLastViewedAt DateTime?
  ownerId           String
  forkedFromId      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  owner         Profile        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  forkedFrom    Table?         @relation("TableForks", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks         Table[]        @relation("TableForks")
  versions      TableVersion[]
  collaborators Collaborator[]

  @@map("tables")
}

model TableVersion {
  id        String   @id @default(cuid())
  tableId   String
  version   Int
  schema    Json
  data      Json?
  message   String?
  createdAt DateTime @default(now())
  authorId  String

  table  Table   @relation(fields: [tableId], references: [id], onDelete: Cascade)
  author Profile @relation("VersionAuthor", fields: [authorId], references: [id])

  @@unique([tableId, version])
  @@map("table_versions")
}

enum CollaboratorRole {
  VIEWER
  EDITOR
  ADMIN
}

model Collaborator {
  id        String           @id @default(cuid())
  tableId   String
  profileId String
  role      CollaboratorRole @default(VIEWER)
  createdAt DateTime         @default(now())

  table   Table   @relation(fields: [tableId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([tableId, profileId])
  @@map("collaborators")
}
